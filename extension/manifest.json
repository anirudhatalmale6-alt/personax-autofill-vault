{
  "manifest_version": 3,
  "name": "PersonaX Autofill",
  "version": "2.0.0",
  "description": "Install and go. Each PersonaX profile gets its own fixed identity and autofills Outlook signup forms. Press Alt+X. No setup, no server.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "PersonaX Autofill" },
  "commands": {
    "autofill": {
      "suggested_key": { "default": "Alt+X" },
      "description": "Autofill the current form"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
