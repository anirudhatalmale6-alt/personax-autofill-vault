{
  "manifest_version": 3,
  "name": "PersonaX Autofill (Alt+X)",
  "version": "1.0.0",
  "description": "Press Alt+X to autofill signup/signin forms with this PersonaX profile's stored account info.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "PersonaX Autofill" },
  "commands": {
    "autofill": {
      "suggested_key": { "default": "Alt+X" },
      "description": "Autofill the current form"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
