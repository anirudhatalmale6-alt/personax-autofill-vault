{
  "manifest_version": 3,
  "name": "PersonaX Autofill",
  "version": "2.2.0",
  "description": "Install and go. Each PersonaX profile opens its own home page on personax.work with its fixed identity. Press Alt+X to fill the Outlook signup. English forced. No setup, no server.",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "PersonaX Autofill" },
  "commands": {
    "autofill": {
      "suggested_key": { "default": "Alt+X" },
      "description": "Autofill the current form"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.live.com/*", "*://*.microsoft.com/*", "*://*.microsoftonline.com/*",
        "*://*.outlook.com/*", "*://*.office.com/*", "*://*.account.microsoft.com/*"
      ],
      "js": ["lang.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
